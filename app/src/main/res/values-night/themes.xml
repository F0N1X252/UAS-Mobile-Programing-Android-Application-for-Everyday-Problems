<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <!-- FIX: parent SEBELUMNYA "Theme.Material3.DayNight.NoActionBar", beda keluarga
         dengan versi light yang pakai "Theme.MaterialComponents.DayNight.NoActionBar".
         Dua sistem tema berbeda ini menyebabkan beberapa attribute (colorSurface,
         colorOnSurface, dll) tidak diwariskan dengan konsisten -> makanya tampilan
         jadi campur aduk. Sekarang disamakan parent-nya dan item-nya dilengkapi
         (style dengan nama sama di folder values-night TIDAK mewarisi item dari
         values/themes.xml secara otomatis, jadi harus ditulis ulang semua). -->
    <style name="Base.Theme.Pengaduan" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
    </style>
</resources>